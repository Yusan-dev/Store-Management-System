        </p>


        <div class="license-access-details">


            <div>

                <span>
                    USER ID
                </span>

                <strong id="expiredUserId">
                    -
                </strong>

            </div>


            <div>

                <span>
                    ACCESS PLAN
                </span>

                <strong>
                    FREE ACCESS
                </strong>

            </div>


            <div>

                <span>
                    FREE ACCESS ENDED
                </span>

                <strong id="expiredDate">
                    29 NOVEMBER 2026
                </strong>

            </div>


            <div>

                <span>
                    STATUS
                </span>

                <strong>
                    ACCESS EXPIRED
                </strong>

            </div>


        </div>


        <div class="license-access-action">

            <strong>
                CONTACT KANGODING.ORG
            </strong>

            <span>
                ACTIVATE VIP LIFETIME ACCESS
            </span>

        </div>


        <div class="license-access-code">

